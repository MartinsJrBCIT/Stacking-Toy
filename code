import time


#Function used to test whether you want to remove a ring or keep placing rings
def removeOrNah():
    if len(stack) == 0:
        print("You need at least 1 ring to remove rings!")
        pass
    else:
        
        print("Do you want to remove a Ring or no?\nY/N")
        remove = input()


        if remove == "Y":
            stack.pop()
            print("Ring removed successfully!")
            removeOrNah()
        
        elif remove == "N":
            print("No ring removed.")
            pass
        else:
            print("Invalid input. Please enter Y or N.")
            removeOrNah()

